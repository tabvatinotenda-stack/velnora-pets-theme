<div style="padding:14px 20px;background:#f5f0e8;border-bottom:0.5px solid #e8e2d9">
  <a href="javascript:history.back()" class="back-btn">
    <i class="ti ti-arrow-left" aria-hidden="true"></i> Back
  </a>
</div>

<div class="pd-layout">
  <div class="pd-img">
    {%- if product.featured_image -%}
      <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.featured_image.alt | escape }}" style="width:100%;height:100%;object-fit:contain;">
    {%- else -%}
      <i class="ti ti-paw" style="color:#2c4a3e;font-size:80px" aria-hidden="true"></i>
    {%- endif -%}
  </div>

  <div class="pd-info">
    <div class="pd-kicker">{{ product.type }}</div>
    <div class="pd-name">{{ product.title }}</div>
    <div class="pd-rule"></div>
    <div class="pd-price">{{ product.price | money }}</div>
    <div class="pd-desc">{{ product.description }}</div>

    <div class="pd-tags">
      {%- for tag in product.tags -%}
        <span class="pd-tag">{{ tag }}</span>
      {%- endfor -%}
    </div>

    <form action="{{ routes.cart_add_url }}" method="post">
      {%- if product.variants.size > 1 -%}
        <div class="form-group" style="margin-bottom:14px">
          <label class="form-label">Option</label>
          <select name="id" class="form-select">
            {%- for variant in product.variants -%}
              <option value="{{ variant.id }}"{% unless variant.available %} disabled{% endunless %}>
                {{ variant.title }}{% unless variant.available %} — Sold out{% endunless %}
              </option>
            {%- endfor -%}
          </select>
        </div>
      {%- else -%}
        <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      {%- endif -%}
      <button type="submit" class="pd-btn">Add to cart</button>
    </form>
  </div>
</div>

{% schema %}
{
  "name": "Product Page"
}
{% endschema %}
