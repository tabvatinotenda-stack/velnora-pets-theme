<div class="trust">
  {% for block in section.blocks %}
    <div class="ti-item" {{ block.shopify_attributes }}>
      <i class="ti {{ block.settings.icon }}" aria-hidden="true"></i>
      {{ block.settings.text }}
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Trust Bar",
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Tabler icon class",
          "default": "ti-truck"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "2–5 day US shipping"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "ti-truck", "text": "2–5 day US shipping" } },
        { "type": "trust_item", "settings": { "icon": "ti-shield-check", "text": "Safe for all breeds" } },
        { "type": "trust_item", "settings": { "icon": "ti-refresh", "text": "Easy returns" } },
        { "type": "trust_item", "settings": { "icon": "ti-star", "text": "4.8 avg rating" } }
      ]
    }
  ]
}
{% endschema %}
