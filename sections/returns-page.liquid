<div class="cat-page-hero">
  <div class="cat-page-kicker">Policies</div>
  <div class="cat-page-title">Returns &amp; Refunds</div>
  <div class="cat-page-rule"></div>
  <div class="cat-page-desc">At Velnora Pets, your satisfaction is important to us.</div>
</div>

<div class="sec" style="max-width:760px">
  <div class="returns-list">

    <div class="return-item">
      <div class="return-icon"><i class="ti ti-calendar" aria-hidden="true"></i></div>
      <div class="return-body">
        <div class="return-title">30-Day return window</div>
        <div class="return-desc">Returns are accepted within 30 days of delivery. Items must be unused, in their original condition, and in the original packaging.</div>
      </div>
    </div>

    <div class="return-item">
      <div class="return-icon"><i class="ti ti-ban" aria-hidden="true"></i></div>
      <div class="return-body">
        <div class="return-title">Personalised items</div>
        <div class="return-desc">Personalized or custom-made products cannot be returned unless they arrive damaged, defective, or incorrect.</div>
      </div>
    </div>

    <div class="return-item">
      <div class="return-icon"><i class="ti ti-alert-circle" aria-hidden="true"></i></div>
      <div class="return-body">
        <div class="return-title">Damaged or incorrect items</div>
        <div class="return-desc">If your item is damaged, defective, or you received the wrong product, please contact us within 7 days of delivery with your order number and photos.</div>
      </div>
    </div>

    <div class="return-item">
      <div class="return-icon"><i class="ti ti-truck-return" aria-hidden="true"></i></div>
      <div class="return-body">
        <div class="return-title">Return shipping costs</div>
        <div class="return-desc">Customers are responsible for return shipping costs unless the return is due to our error.</div>
      </div>
    </div>

    <div class="return-item">
      <div class="return-icon"><i class="ti ti-credit-card" aria-hidden="true"></i></div>
      <div class="return-body">
        <div class="return-title">Refund processing</div>
        <div class="return-desc">Approved refunds will be processed to your original payment method within 5–10 business days after we receive and inspect the returned item.</div>
      </div>
    </div>

  </div>

  <div class="returns-cta">
    <div class="sec-kicker">Ready to return?</div>
    <div class="sec-title">Start a return</div>
    <div class="sec-rule"></div>
    <p style="font:300 12px/1.8 'Raleway',sans-serif;color:#4a7c59;margin-bottom:20px">Contact us before sending your item back. Include your order number and reason for return.</p>
    <a href="mailto:support@velnorapets.com" class="btn-solid">Email support@velnorapets.com</a>
  </div>
</div>

{% schema %}
{
  "name": "Returns Page"
}
{% endschema %}
