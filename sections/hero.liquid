<div class="hero">
  <div class="hero-text">
    <div class="hero-kicker">Better Living for Every Paw.</div>
    <div class="hero-h1">Premium<br>pet accessories</div>
    <div class="hero-rule"></div>
    <p class="hero-p">Grooming kits, lick mats, harnesses, toys and more — curated for dogs who deserve the best.</p>
    <div class="hero-btns">
      <a href="{{ collections.all.url }}" class="btn-solid">Shop now</a>
      <a href="{{ pages['about'].url }}" class="btn-out">Our story</a>
    </div>
  </div>
  <div class="hero-img">
    {%- if section.settings.hero_image != blank -%}
      <img src="{{ section.settings.hero_image | image_url: width: 400 }}" alt="Velnora Pets" style="width:100%;height:100%;object-fit:cover;border-radius:3px;">
    {%- else -%}
      <svg width="64" height="56" viewBox="0 0 40 36" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="7" cy="11" r="4" fill="#c9a96e"/>
        <circle cx="15" cy="7" r="3.5" fill="#c9a96e"/>
        <circle cx="25" cy="7" r="3.5" fill="#c9a96e"/>
        <circle cx="33" cy="11" r="4" fill="#c9a96e"/>
        <ellipse cx="20" cy="27" rx="11" ry="9" fill="#c9a96e"/>
      </svg>
      <div class="hero-hint">Add lifestyle photo</div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
