<div class="faq-sec">
  <div class="sec-kicker">{{ section.settings.kicker }}</div>
  <div class="sec-title">{{ section.settings.title }}</div>
  <div class="sec-rule"></div>

  {% for block in section.blocks %}
    <div class="faq-item" onclick="toggleFaq(this)" {{ block.shopify_attributes }}>
      <div class="faq-q">{{ block.settings.question }} <i class="ti ti-chevron-down" aria-hidden="true"></i></div>
      <div class="faq-a">{{ block.settings.answer }}</div>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker text",
      "default": "Common questions"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "FAQ"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Your question here"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Your answer here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "Where do you ship from?",
            "answer": "All our products ship from USA-based warehouses. Most orders arrive within 2–5 business days depending on your location."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Do you offer free shipping?",
            "answer": "Yes! We offer free standard US shipping on all orders over $35. Orders under $35 have a flat $4.99 shipping fee."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Can I return a product?",
            "answer": "Absolutely. We accept returns within 30 days of delivery for unused items in original condition. Contact us to start a return."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Are your products safe for pets?",
            "answer": "Yes — every product we carry is tested for pet safety. We only stock non-toxic, pet-safe materials from verified suppliers."
          }
        }
      ]
    }
  ]
}
{% endschema %}
