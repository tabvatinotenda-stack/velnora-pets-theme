<div class="faq-sec">
  <div class="sec-kicker">{{ section.settings.kicker }}</div>
  <div class="sec-title">{{ section.settings.title }}</div>
  <div class="sec-rule"></div>

  {% for block in section.blocks %}
    <div class="faq-item" onclick="toggleFaq(this)" {{ block.shopify_attributes }}>
      <div class="faq-q">{{ block.settings.question }} <i class="ti ti-chevron-down" aria-hidden="true"></i></div>
      <div class="faq-a">{{ block.settings.answer }}</div>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker text",
      "default": "Common questions"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "FAQ"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Your question here"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Your answer here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "Where do you ship from?",
            "answer": "All our products ship from USA-based warehouses. Most orders arrive within 3–8 business days depending on your location."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How much does shipping cost?",
            "answer": "Standard shipping is $5.99 and takes 3–8 business days. Free shipping is available on all orders over $35."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Can I return a product?",
            "answer": "Yes — we accept returns within 30 days of delivery for unused items in their original condition and packaging. Personalized items cannot be returned unless damaged or incorrect. To start a return, contact us at support@velnorapets.com."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What if my item arrives damaged or incorrect?",
            "answer": "Please contact us within 7 days of delivery with your order number and photos. We will make it right at no cost to you."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How long do refunds take?",
            "answer": "Approved refunds are processed to your original payment method within 5–10 business days after we receive and inspect the returned item."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Are your products safe for pets?",
            "answer": "Yes — every product we carry is tested for pet safety. We only stock non-toxic, pet-safe materials from verified suppliers."
          }
        }
      ]
    }
  ]
}
{% endschema %}
