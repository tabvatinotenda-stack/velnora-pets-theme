<div class="faq-sec">
  <div class="sec-kicker">Common questions</div>
  <div class="sec-title">FAQ</div>
  <div class="sec-rule"></div>

  <div class="faq-item" onclick="toggleFaq(this)">
    <div class="faq-q">Where do you ship from? <i class="ti ti-chevron-down" aria-hidden="true"></i></div>
    <div class="faq-a">All our products ship from USA-based warehouses. Most orders arrive within 2–5 business days depending on your location.</div>
  </div>
  <div class="faq-item" onclick="toggleFaq(this)">
    <div class="faq-q">Do you offer free shipping? <i class="ti ti-chevron-down" aria-hidden="true"></i></div>
    <div class="faq-a">Yes! We offer free standard US shipping on all orders over $35. Orders under $35 have a flat $4.99 shipping fee.</div>
  </div>
  <div class="faq-item" onclick="toggleFaq(this)">
    <div class="faq-q">Can I return a product? <i class="ti ti-chevron-down" aria-hidden="true"></i></div>
    <div class="faq-a">Absolutely. We accept returns within 30 days of delivery for unused items in original condition. Contact us to start a return.</div>
  </div>
  <div class="faq-item" onclick="toggleFaq(this)">
    <div class="faq-q">Are your products safe for pets? <i class="ti ti-chevron-down" aria-hidden="true"></i></div>
    <div class="faq-a">Yes — every product we carry is tested for pet safety. We only stock non-toxic, pet-safe materials from verified suppliers.</div>
  </div>
</div>

{% schema %}
{
  "name": "FAQ",
  "presets": [{ "name": "FAQ" }]
}
{% endschema %}
